FROM python:3.12-slim AS builder
WORKDIR /app
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY backend/ .
# Copy Quran data to the expected location
RUN mkdir -p /frontend/src/lib/quran
COPY frontend/src/lib/quran/quran_id.json /frontend/src/lib/quran/quran_id.json
EXPOSE 8000
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
